# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# AGNES_API_KEY: Required for Agnes AI API calls (video and image generation).
AGNES_API_KEY="MY_AGNES_API_KEY"

# MISTRAL_API_KEY: Required for Mistral AI API calls.
MISTRAL_API_KEY="MY_MISTRAL_API_KEY"

# APP_URL: The URL where this app is hosted (e.g. Railway public URL).
APP_URL="MY_APP_URL"

# CATBOX_USERHASH: Catbox.moe account userhash for PERMANENT file storage.
# Without this, uploads are anonymous (may be removed after long inactivity).
# How to get it:
# 1. Register/login at https://catbox.moe
# 2. Open https://catbox.moe/user/manage.php (or Account page)
# 3. Copy your "userhash" and paste below (or set in Railway Variables)
CATBOX_USERHASH=""
